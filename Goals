    @Test
    public void testMoveToBin() throws Exception{
       ContactEntity contactEntity = service.getContact(id);

       if(contactEntity.getStatus() == Status.TRASH)
           throw new Exception("The contact is already at the bin !");

       boolean result = service.moveToBin(id);

       assertTrue(result);
    }

    @Test
    public void testRestoreFromBin() throws Exception{
        ContactEntity contactEntity = service.getContact(id);

        if(contactEntity.getStatus() != Status.TRASH)
            throw new Exception("The contact is already at the contact book !");

        boolean result = service.restoreFromBin(id);

        assertTrue(result);
    }